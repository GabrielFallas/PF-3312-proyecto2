# ============================================================
#  Plantilla de variables de entorno  ->  copiar a  .env
#  El archivo .env real NUNCA se sube al repositorio (.gitignore).
# ============================================================
#
#  Los servicios en la NUBE se activan SOLO si su API key esta
#  definida aqui. Si dejas una vacia, ese servicio se omite
#  automaticamente y el resto del benchmark continua.
#
#  Todas las llaves usadas corresponden a CAPAS GRATUITAS
#  (free tier) para mantener el costo en cero. Ver README.md
#  para los enlaces de registro de cada proveedor.

# ============================================================
#  PARAMETROS GENERALES
# ============================================================
N_RUNS=5
RESULTS_DIR=results
OLLAMA_HOST=http://localhost:11434

# ============================================================
#  LLM (Lenguaje)
# ============================================================
# Nube alta gama - Google AI Studio (free tier): https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Nube alta gama - OpenAI (opcional, requiere saldo): https://platform.openai.com
OPENAI_API_KEY=
# Nube bajo costo / alta velocidad - Groq (free tier): https://console.groq.com/keys
GROQ_API_KEY=
# (Los LLM locales via Ollama no requieren llave.)

# ============================================================
#  STT (Reconocimiento de voz)
# ============================================================
# Nube alta gama - Deepgram ($200 credito gratis): https://console.deepgram.com
DEEPGRAM_API_KEY=
# Nube alta gama - AssemblyAI (free tier): https://www.assemblyai.com
ASSEMBLYAI_API_KEY=
# Nube bajo costo - Groq Whisper usa la misma GROQ_API_KEY de arriba.

# ============================================================
#  TTS (Sintesis de voz)
# ============================================================
# Nube alta gama - ElevenLabs (10k caracteres/mes gratis): https://elevenlabs.io
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL
# Nube alta gama - Azure Speech (free tier F0): https://portal.azure.com
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=eastus
# Nube bajo costo - OpenAI TTS usa la misma OPENAI_API_KEY de arriba.

# ============================================================
#  MODELOS LOCALES OPCIONALES (rutas)
# ============================================================
# whisper.cpp (binario y modelo .bin compilados localmente)
WHISPER_CPP_BIN=
WHISPER_CPP_MODEL=
# Vosk (modelo en espanol descomprimido): https://alphacephei.com/vosk/models
VOSK_MODEL_PATH=models/vosk-model-small-es-0.42
VOSK_SAMPLE_RATE=16000
# Piper (voz .onnx + .onnx.json): https://github.com/rhasspy/piper
PIPER_VOICE=models/piper/es_ES-davefx-medium.onnx
