# ============================================================
#  Plantilla de variables de entorno  ->  copiar a  .env
#  (el archivo .env real NUNCA se sube al repositorio)
# ============================================================
#
#  Este proyecto usa EXCLUSIVAMENTE servicios locales y de
#  codigo abierto (Ollama / Docker / pip). No se requieren
#  llaves de API de pago. Las variables de abajo solo
#  parametrizan rutas y endpoints locales.

# --- Servidor Ollama (LLMs locales) ---
OLLAMA_HOST=http://localhost:11434

# --- Numero de ejecuciones por prueba (la rubrica exige >= 5) ---
N_RUNS=5

# --- Directorio donde se persisten los resultados crudos ---
RESULTS_DIR=results

# --- Rutas de binarios opcionales (si no estan en el PATH) ---
# Ruta al ejecutable de whisper.cpp (build local), p.ej. ./whisper.cpp/main
WHISPER_CPP_BIN=
# Modelo .bin para whisper.cpp, p.ej. ./whisper.cpp/models/ggml-base.bin
WHISPER_CPP_MODEL=

# --- Ruta al modelo Vosk descomprimido (es) ---
# Descargar de https://alphacephei.com/vosk/models
VOSK_MODEL_PATH=models/vosk-model-small-es-0.42

# --- Ruta a la voz Piper (.onnx) y su config (.onnx.json) ---
VOSK_SAMPLE_RATE=16000
PIPER_VOICE=models/piper/es_ES-davefx-medium.onnx
