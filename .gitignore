# === Credenciales y entorno (NUNCA subir) ===
.env
.env.local
*.key
*.pem
secrets/

# === Entornos virtuales ===
.venv/
venv/
env/
ENV/

# === Resultados crudos y artefactos pesados ===
results/*.csv
results/*.json
results/raw/
report/figures/*.png
report/.reporte_pdf.md          # temporal del build de PDF

# Binarios de herramientas portables (p.ej. tectonic para generar el PDF)
.tools/

# NOTA: el PDF final del reporte (report/reporte_tecnico.pdf) SI se versiona
# como entregable; los datos (results/*.csv) y figuras se anaden con `git add -f`.

# Audios generados / de prueba (pesados)
data/audio/*.wav
data/audio/*.mp3
data/audio/*.flac
tts_output/
# EXCEPCION: el audio de prueba de STT si se versiona (reproducibilidad sin claves)
!data/audio/muestra_es.wav

# Modelos descargados localmente (pesados)
models/
*.gguf
*.bin
*.onnx
*.pt
*.pth

# === Python ===
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ipynb_checkpoints/

# === Sistema operativo / editor ===
.DS_Store
Thumbs.db
.vscode/
.idea/

# Mantener carpetas vacías versionadas
!results/.gitkeep
!data/audio/.gitkeep
!report/figures/.gitkeep
